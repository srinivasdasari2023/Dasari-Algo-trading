# CapitalGuard Algo Trader – Environment Example
# Copy to .env and fill; never commit .env

# App
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/capitalguard
DATABASE_POOL_SIZE=5

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_LOCK_PREFIX=capitalguard:lock

# Upstox (use sandbox for non-prod)
UPSTOX_API_BASE_URL=https://api.upstox.com/v2
# Must match EXACTLY the Redirect URI in your Upstox developer dashboard (e.g. http://localhost:3000/auth/callback)
UPSTOX_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
# UPSTOX_CLIENT_ID= from Upstox app
# UPSTOX_CLIENT_SECRET= from Upstox app

# JWT / Session (generate secure secret)
JWT_SECRET=your-256-bit-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Risk (override defaults; optional)
MAX_TRADES_PER_DAY=3
SQUARE_OFF_TIME=15:15
ENTRY_CUTOFF_TIME=12:30

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email (Gmail) – login, trading signals, orders, SL/TSL
# Set MAIL_ENABLED=true or provide all of FROM/TO/PASSWORD to enable
MAIL_ENABLED=false
MAIL_FROM=your@gmail.com
MAIL_TO=your@gmail.com
# Gmail app password: https://myaccount.google.com/apppasswords (or use MAIL_PASSWORD)
MAIL_APP_PASSWORD=your-16-char-app-password
